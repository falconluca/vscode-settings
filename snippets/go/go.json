{
  "示例文件模板": {
    "prefix": "ignoremain",
    "body": ["//go:build ignore", "// +build ignore"]
  },
  "main 函数": {
    "prefix": "main",
    "body": ["func main() {", "\t$0", "}"]
  },
  "if err != nil 检查": {
    "prefix": "errnil",
    "body": ["if err != nil {", "\treturn ${1:fmt.Errorf(\"%w\", err)}", "}$0"]
  },
  "定义接收者方法 (receiver *Type)": {
    "prefix": "recv",
    "body": [
      "func (${1:receiver} *${2:Type}) ${3:MethodName}(${4:args}) ${5:returnType} {",
      "\t$0",
      "}"
    ]
  }
}
