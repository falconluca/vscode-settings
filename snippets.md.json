{
  "插入表格": {
    "prefix": "tb",
    "body": [
      "| ${1:标题1} | ${2:标题2} |",
      "|--------|--------|",
      "| ${3:内容} | ${4:内容} |",
      "| ${5:内容} | ${6:内容} |"
    ],
    "description": "插入表格（2 列 × 2 行，含表头）"
  },

  "表格追加行": {
    "prefix": "trow",
    "body": ["| ${1:内容} | ${2:内容} |"],
    "description": "表格追加一行（2 列）"
  },

  "代码块": {
    "prefix": "code",
    "body": ["```${1:language}", "$0", "```"],
    "description": "代码块（可指定语言）"
  },

  "引用": {
    "prefix": "quote",
    "body": ["> ${1:引用内容}", "$0"],
    "description": "引用块"
  },

  "链接": {
    "prefix": "link",
    "body": ["[${1:文本}](${2:https://})"],
    "description": "超链接"
  },

  "图片": {
    "prefix": "img",
    "body": ["![${1:alt 文本}](${2:https://})"],
    "description": "图片"
  },

  "徽章": {
    "prefix": "badge",
    "body": [
      "![${1:标题}](https://img.shields.io/badge/${2:label}-${3:message}-${4:blue})"
    ],
    "description": "shields.io 徽章"
  },

  "任务项": {
    "prefix": "task",
    "body": ["- [ ] ${1:待办事项}"],
    "description": "任务项（复选框）"
  },

  "分隔线": {
    "prefix": "hr",
    "body": ["", "---", ""],
    "description": "分隔线（前后留空行，避免与标题冲突）"
  },

  "折叠块": {
    "prefix": "details",
    "body": [
      "<details>",
      "<summary>${1:点击展开}</summary>",
      "",
      "$0",
      "",
      "</details>"
    ],
    "description": "折叠块（<details>，README 常用）"
  },

  "注释": {
    "prefix": "cmt",
    "body": ["<!-- $0 -->"],
    "description": "HTML 注释（Markdown 中不渲染）"
  }
}
